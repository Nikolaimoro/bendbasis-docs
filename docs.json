{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "bendbasis docs",
  "colors": {
    "primary": "#60A5FA",
    "light": "#93C5FD",
    "dark": "#1D4ED8",
    "background": {
      "light": "#1C202F",
      "dark": "#1C202F"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "index",
              "api-reference/introduction"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Guides",
            "pages": [
              "guides/coming-soon"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Main Site",
          "href": "https://bendbasis.com",
          "icon": "globe"
        },
        {
          "anchor": "Open App",
          "href": "https://bendbasis.com/funding",
          "icon": "arrow-up-right-from-square"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Main Site",
      "href": "https://bendbasis.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/bendbasis",
      "telegram": "https://t.me/bendbasis"
    }
  }
}
