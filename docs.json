{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "bendbasis docs",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "modeToggle": {
    "default": "dark"
  },
  "favicon": "/favicon.ico",
  "openapi": "/api-reference/openapi.json",
  "api": {
    "baseUrl": "https://bendbasis.com",
    "playground": {
      "mode": "show"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Guides",
            "pages": [
              "index",
              "guides/coming-soon"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Funding",
            "pages": [
              "api-reference/funding/markets",
              "api-reference/funding/arbitrage",
              "api-reference/funding/history"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Main Site",
          "href": "https://bendbasis.com/funding",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Main Site",
      "href": "https://bendbasis.com/funding"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/bendbasis",
      "telegram": "https://t.me/bendbasis"
    }
  }
}
